        <button class="btn-ghost" onclick="fecharModal('novaSessao')">Cancelar</button>
        <button class="btn-primary-modal" onclick="criarSessao()">
          <i class="bi bi-plus-lg me-1"></i>Criar Sessão
        </button>
      </div>
    </div>
  </div>
  @end

  @slot('scripts')
  <script>
  function abrirModal(id) {
    document.getElementById('modal-' + id).classList.add('open')
    document.body.style.overflow = 'hidden'
  }
  function fecharModal(id) {
    document.getElementById('modal-' + id).classList.remove('open')
    document.body.style.overflow = ''
  }
  document.querySelectorAll('.modal-overlay').forEach(m =>
    m.addEventListener('click', e => { if (e.target === m) { m.classList.remove('open'); document.body.style.overflow = '' } })
  )

  async function criarSessao() {
    const body = {
      tipo: document.getElementById('ns-tipo').value,
      numero: document.getElementById('ns-numero').value,
      descricao: document.getElementById('ns-descricao').value,
      data_sessao: document.getElementById('ns-data').value,
      hora_inicio: document.getElementById('ns-hora').value,
      local: document.getElementById('ns-local').value,
    }
    const r = await fetch('/controle/votacao/sessoes', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body)
    })
    if (r.ok) { fecharModal('novaSessao'); location.reload() }
    else { const e = await r.json(); alert(e.error || 'Erro ao criar sessão') }
  }

  async function iniciarSessao(id) {
    if (!confirm('Iniciar esta sessão?')) return
    await fetch('/controle/votacao/sessoes/' + id + '/iniciar', { method: 'POST' })
    location.reload()
  }

  async function encerrarSessao(id) {
    if (!confirm('Encerrar a sessão atual?')) return
    await fetch('/controle/votacao/sessoes/' + id + '/encerrar', { method: 'POST' })
    location.reload()
  }

  async function excluirSessao(id) {
    if (!confirm('Excluir esta sessão?')) return
    await fetch('/controle/votacao/sessoes/' + id, { method: 'DELETE' })
    location.reload()
  }

  // Preenche data com hoje
  document.getElementById('ns-data').value = new Date().toISOString().split('T')[0]
  </script>
  @end
@end
