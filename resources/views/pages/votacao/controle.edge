              <div class="fs-3 fw-bold text-white">{{ totalSessoes }}</div>
              <div class="text-secondary small">Sessões realizadas</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    {{-- Modal Nova Sessao --}}
    <div class="modal fade" id="modalNovaSessao" tabindex="-1">
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title text-white">Nova Sessao</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body">
            <div class="mb-3">
              <label class="form-label text-secondary small">Tipo</label>
              <select id="tipo" class="form-select">
                <option value="ordinaria">Ordinaria</option>
                <option value="extraordinaria">Extraordinaria</option>
                <option value="solene">Solene</option>
              </select>
            </div>
            <div class="mb-3">
              <label class="form-label text-secondary small">Data</label>
              <input type="date" id="data_sessao" class="form-control">
            </div>
            <div class="mb-3">
              <label class="form-label text-secondary small">Local</label>
              <input type="text" id="local" class="form-control" value="Plenario da Camara">
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
            <button type="button" class="btn btn-primary" onclick="criarSessao()">Criar e Iniciar</button>
          </div>
        </div>
      </div>
    </div>
  @end

  @slot('scripts')
  <script>
  async function criarSessao() {
    const r = await fetch('/controle/votacao/sessoes', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        tipo: document.getElementById('tipo').value,
        data_sessao: document.getElementById('data_sessao').value,
        local: document.getElementById('local').value,
      })
    })
    if (r.ok) location.reload()
  }
  async function encerrarSessao(id) {
    if (!confirm('Encerrar a sessao?')) return
    await fetch('/controle/votacao/sessoes/' + id + '/encerrar', { method: 'POST' })
    location.reload()
  }
  </script>
  @end
@end
