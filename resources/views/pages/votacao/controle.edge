<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>VotaLegis — Controle</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-dark text-white p-4">
  <h1>✅ Controle funcionando!</h1>
  <p>municipioId na sessão: {{ sessaoMunicipioId }}</p>
  <p>Sessão ativa: {{ sessao ? sessao.tipo + ' — ' + sessao.data_sessao : 'Nenhuma' }}</p>
  <p>Total vereadores: {{ totalVereadores }}</p>
  <p>Total sessões: {{ totalSessoes }}</p>
  <hr>
  <a href="/logout" class="btn btn-danger">Sair</a>
</body>
</html>
