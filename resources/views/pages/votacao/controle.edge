        <div class="form-group">
          <label>Descrição / Pauta</label>
          <input type="text" id="ns-descricao" class="form-input" placeholder="Ex: 1ª Sessão Ordinária de Março">
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Data *</label>
            <input type="date" id="ns-data" class="form-input">
          </div>
          <div class="form-group">
            <label>Horário</label>
            <input type="time" id="ns-hora" class="form-input" value="10:00">
          </div>
        </div>
        <div class="form-group">
          <label>Local</label>
          <input type="text" id="ns-local" class="form-input" value="Plenário da Câmara">
        </div>
      </div>
