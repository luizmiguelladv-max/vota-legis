        <div class="flex-grow-1">
          <strong>Sessão em andamento:</strong> {{ sessao.tipo }} — {{ sessao.data_sessao }}
        </div>
        <button class="btn btn-sm btn-danger" onclick="encerrarSessao({{ sessao.id }})">
          <i class="bi bi-stop-circle me-1"></i>Encerrar
        </button>
      </div>
    @else
      <div class="alert alert-info d-flex align-items-center gap-3">
        <i class="bi bi-info-circle-fill fs-4"></i>
        <div class="flex-grow-1">Nenhuma sessão em andamento.</div>
        <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#modalNovaSessao">
          <i class="bi bi-plus-circle me-1"></i>Iniciar Sessão
        </button>
      </div>
    @end

    <div class="row g-3">
      <div class="col-md-4">
        <div class="card">
          <div class="card-body d-flex align-items-center gap-3">
            <div class="rounded-circle bg-primary bg-opacity-25 p-3">
              <i class="bi bi-people text-primary fs-5"></i>
            </div>
            <div>
              <div class="fs-3 fw-bold text-white">{{ totalVereadores }}</div>
              <div class="text-secondary small">Vereadores ativos</div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card">
