<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>VotaLegis · {{ vereador?.nome_parlamentar || 'App' }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&family=JetBrains+Mono:wght@600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
  <style>
    :root{--p:#2563eb;--p-dark:#1d4ed8;--p-light:#dbeafe;--p-rgb:37,99,235}
    *{box-sizing:border-box;margin:0;padding:0;font-family:'Plus Jakarta Sans',sans-serif;-webkit-tap-highlight-color:transparent}
    body{background:#f1f5f9;min-height:100vh;max-width:430px;margin:0 auto}

    /* HEADER */
    .app-header{background:linear-gradient(135deg,var(--p),var(--p-dark));padding:52px 20px 20px;color:#fff;position:relative;overflow:hidden}
    .app-header::before{content:'';position:absolute;top:-40%;right:-10%;width:200px;height:200px;background:rgba(255,255,255,.07);border-radius:50%}
    .header-inner{position:relative}
    .vereador-av{width:52px;height:52px;border-radius:13px;background:rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;font-weight:800;font-size:1.2rem;color:#fff;margin-bottom:10px;border:2px solid rgba(255,255,255,.3)}
    .header-name{font-size:1.2rem;font-weight:800;letter-spacing:-.02em}
    .header-sub{font-size:.8rem;opacity:.75;margin-top:2px}
    .header-badges{display:flex;gap:8px;margin-top:10px}
    .hbadge{display:flex;align-items:center;gap:5px;background:rgba(255,255,255,.15);padding:5px 11px;border-radius:99px;font-size:.73rem;font-weight:600}

    /* SCREENS */
    .screen{display:none;padding:16px;padding-bottom:90px}
    .screen.active{display:block}

    /* BOTTOM NAV */
    .bottom-nav{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:430px;background:#fff;border-top:1px solid #e2e8f0;display:flex;padding:8px 0 max(8px,env(safe-area-inset-bottom));z-index:50;box-shadow:0 -4px 20px rgba(15,23,42,.08)}
    .nav-btn{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;padding:6px 0;cursor:pointer;border:none;background:transparent;color:#94a3b8;transition:color .2s;font-size:.65rem;font-weight:700}
    .nav-btn.active{color:var(--p)}
    .nav-btn i{font-size:1.3rem}

    /* CARDS */
    .card{background:#fff;border-radius:14px;border:1px solid #e2e8f0;margin-bottom:12px}
    .card-pad{padding:16px 18px}
    .card-title{font-weight:700;font-size:.88rem;color:#0f172a;margin-bottom:12px;display:flex;align-items:center;gap:8px}

    /* SESSAO STATUS */
    .sessao-status{padding:16px 18px;border-radius:14px;margin-bottom:12px}
    .s-ativa{background:linear-gradient(135deg,var(--p),var(--p-dark));color:#fff}
    .s-idle{background:#fff;border:1px solid #e2e8f0;color:#64748b;display:flex;flex-direction:column;align-items:center;padding:32px;text-align:center}

    /* PRESENÇA */
    .presenca-card{border-radius:14px;padding:16px 18px;margin-bottom:12px;display:flex;align-items:center;justify-content:space-between;gap:12px}
    .p-presente{background:linear-gradient(135deg,#f0fdf4,#dcfce7);border:2px solid #86efac}
    .p-ausente{background:#fff;border:1px solid #e2e8f0}

    /* VOTE BUTTONS */
    .vote-btn{width:100%;border:none;border-radius:14px;padding:18px;display:flex;align-items:center;justify-content:center;gap:12px;font-size:1rem;font-weight:800;cursor:pointer;transition:transform .15s,filter .15s;margin-bottom:10px}
    .vote-btn:active{transform:scale(.97)}
    .vote-sim{background:linear-gradient(135deg,#22c55e,#16a34a);color:#fff;box-shadow:0 6px 20px rgba(34,197,94,.35)}
    .vote-nao{background:linear-gradient(135deg,#ef4444,#dc2626);color:#fff;box-shadow:0 6px 20px rgba(239,68,68,.35)}
    .vote-abs{background:#f8fafc;color:#475569;border:2px solid #e2e8f0}
    .vote-btn:hover{filter:brightness(1.05)}

    /* BADGE */
    @keyframes pulseRing{0%{transform:scale(.85);opacity:1}100%{transform:scale(2.2);opacity:0}}
    .live-dot{position:relative;display:inline-flex;width:8px;height:8px}
    .live-dot::before{content:'';position:absolute;inset:0;border-radius:50%;background:#22c55e;animation:pulseRing 1.5s infinite}
    .live-dot::after{content:'';position:absolute;inset:0;border-radius:50%;background:#22c55e}
    .badge-live{display:inline-flex;align-items:center;gap:5px;background:rgba(255,255,255,.2);padding:4px 10px;border-radius:99px;font-size:.72rem;font-weight:700}
    .badge-result{padding:4px 10px;border-radius:99px;font-size:.72rem;font-weight:700}
    .br-sim{background:#dcfce7;color:#15803d}
    .br-nao{background:#fee2e2;color:#b91c1c}
    .br-abs{background:#e0f2fe;color:#0369a1}

    /* MATÉRIA ITEM */
    .materia-item{padding:12px 14px;border-bottom:1px solid #f8fafc;display:flex;align-items:flex-start;gap:10px}
    .materia-item:last-child{border-bottom:none}

    /* FORM */
    .form-input{width:100%;padding:10px 13px;border:1.5px solid #e2e8f0;border-radius:9px;font-size:.875rem;color:#0f172a;background:#fff;font-family:'Plus Jakarta Sans',sans-serif}
    .form-input:focus{outline:none;border-color:var(--p);box-shadow:0 0 0 3px rgba(var(--p-rgb),.12)}
    .btn-primary{background:linear-gradient(135deg,var(--p),var(--p-dark));color:#fff;border:none;border-radius:10px;padding:12px 20px;font-size:.9rem;font-weight:700;cursor:pointer;width:100%;display:flex;align-items:center;justify-content:center;gap:8px;transition:filter .15s}
    .btn-primary:hover{filter:brightness(1.06)}
    .btn-ghost{background:#fff;color:#475569;border:1.5px solid #e2e8f0;border-radius:10px;padding:11px 20px;font-size:.88rem;font-weight:600;cursor:pointer;width:100%;transition:background .15s}

    @keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
    .fade-in{animation:fadeIn .25s ease both}
  </style>
</head>
<body>

<div class="app-header">
  <div class="header-inner">
    <div class="vereador-av">{{ (vereador?.nome_parlamentar || 'V').substring(0,1).toUpperCase() }}</div>
    <div class="header-name">{{ vereador?.nome_parlamentar || 'Vereador' }}</div>
    <div class="header-sub">{{ vereador?.cargo || 'Vereador(a)' }} · {{ vereador?.partido_sigla || '' }}</div>
    <div class="header-badges">
      <div class="hbadge"><i class="bi bi-building-fill"></i>{{ municipio?.nome || 'Câmara' }}</div>
      @if(sessao)
        <div class="hbadge"><span class="live-dot"></span>Sessão ativa</div>
      @end
    </div>
  </div>
</div>

{{-- SCREEN: HOME --}}
<div id="screen-home" class="screen active fade-in">
  @if(sessao)
    <div class="sessao-status s-ativa">
      <div style="font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;opacity:.8;margin-bottom:6px">Sessão em andamento</div>
      <div style="font-size:1.1rem;font-weight:800;margin-bottom:4px">{{ sessao.descricao || sessao.tipo }}</div>
      <div style="font-size:.8rem;opacity:.75">{{ sessao.data_sessao }}@if(sessao.hora_inicio) · {{ sessao.hora_inicio }}@end</div>
    </div>

    {{-- PRESENÇA --}}
    <div class="presenca-card {{ presente ? 'p-presente' : 'p-ausente' }}">
      <div>
        <div style="font-weight:700;font-size:.88rem;color:#0f172a">Presença</div>
        <div style="font-size:.75rem;color:#64748b;margin-top:2px">{{ presente ? 'Você está presente' : 'Confirme sua presença' }}</div>
      </div>
      @if(!presente)
        <button style="background:var(--p);color:#fff;border:none;border-radius:9px;padding:9px 16px;font-weight:700;font-size:.83rem;cursor:pointer" onclick="confirmarPresenca()">
          <i class="bi bi-check-lg"></i> Confirmar
        </button>
      @else
        <div style="color:#16a34a;font-size:.9rem"><i class="bi bi-check-circle-fill"></i></div>
      @end
    </div>

    {{-- VOTAÇÃO ATIVA --}}
    @if(votacaoAtiva)
    <div class="card" id="card-votacao">
      <div class="card-pad">
        <div style="display:flex;align-items:center;gap:6px;margin-bottom:8px"><span class="live-dot"></span><span style="font-size:.72rem;font-weight:700;color:var(--p)">VOTAÇÃO ABERTA</span></div>
        <div style="font-weight:700;font-size:.95rem;color:#0f172a;margin-bottom:14px">{{ votacaoAtiva.titulo || votacaoAtiva.ementa || 'Matéria em votação' }}</div>
        @if(meuVoto)
          <div style="text-align:center;padding:12px;background:#f8fafc;border-radius:10px">
            <div style="font-size:.8rem;color:#64748b;margin-bottom:6px">Seu voto</div>
            <span class="badge-result {{ meuVoto === 'sim' ? 'br-sim' : meuVoto === 'nao' ? 'br-nao' : 'br-abs' }}" style="font-size:.9rem;padding:6px 16px">
              {{ meuVoto === 'sim' ? 'A Favor' : meuVoto === 'nao' ? 'Contra' : 'Abstenção' }}
            </span>
          </div>
        @else
          <button class="vote-btn vote-sim" onclick="votar('sim')"><i class="bi bi-hand-thumbs-up-fill"></i>A FAVOR</button>
          <button class="vote-btn vote-nao" onclick="votar('nao')"><i class="bi bi-hand-thumbs-down-fill"></i>CONTRA</button>
          <button class="vote-btn vote-abs" onclick="votar('abstencao')"><i class="bi bi-dash-circle"></i>Abstenção</button>
        @end
      </div>
    </div>
    @end

    {{-- PEDIR VOZ --}}
    <div class="card card-pad">
      <div class="card-title"><i class="bi bi-mic-fill" style="color:var(--p)"></i>Inscrição para fala</div>
      @if(inscrito)
        <div style="text-align:center;padding:12px;background:#fef3c7;border-radius:10px;color:#92400e">
          <i class="bi bi-clock-history"></i>
          <div style="font-weight:700;margin-top:4px">Na fila · posição {{ inscrito.posicao }}</div>
          <button onclick="cancelarVoz()" style="background:transparent;border:none;color:#dc2626;font-size:.8rem;font-weight:600;cursor:pointer;margin-top:8px">Cancelar inscrição</button>
        </div>
      @else
        <div style="display:flex;gap:8px">
          <select id="sel-tempo" class="form-input" style="flex:1">
            <option value="3">3 minutos</option>
            <option value="5">5 minutos</option>
            <option value="10">10 minutos</option>
          </select>
          <button onclick="pedirVoz()" style="background:var(--p);color:#fff;border:none;border-radius:9px;padding:10px 16px;font-weight:700;font-size:.83rem;cursor:pointer;white-space:nowrap"><i class="bi bi-mic-fill"></i> Pedir voz</button>
        </div>
      @end
    </div>

  @else
    <div class="card">
      <div class="sessao-status s-idle">
        <i class="bi bi-calendar-x" style="font-size:2.5rem;margin-bottom:12px"></i>
        <div style="font-weight:700;color:#0f172a;margin-bottom:4px">Sem sessão em andamento</div>
        <div style="font-size:.82rem">Aguarde o início da próxima sessão.</div>
      </div>
    </div>
  @end
</div>

{{-- SCREEN: PAUTA --}}
<div id="screen-pauta" class="screen">
  <div style="font-weight:800;font-size:1rem;color:#0f172a;margin-bottom:14px">Pauta da Sessão</div>
  @if(sessao && materias && materias.length)
    <div class="card">
      @each(m in materias)
      <div class="materia-item">
        <div style="font-size:.72rem;font-weight:700;color:#94a3b8;font-family:'JetBrains Mono',monospace;padding-top:2px;flex-shrink:0">{{ String(loop.index+1).padStart(2,'0') }}</div>
        <div style="flex:1;min-width:0">
          <div style="display:flex;align-items:center;gap:6px;margin-bottom:4px">
            @if(m.status === 'em_votacao')
              <span style="background:var(--p);color:#fff;padding:1px 7px;border-radius:99px;font-size:.65rem;font-weight:700">EM VOTAÇÃO</span>
            @elseif(m.status === 'aprovada')
              <span class="badge-result br-sim">APROVADA</span>
            @elseif(m.status === 'rejeitada')
              <span class="badge-result br-nao">REJEITADA</span>
            @else
              <span style="background:#f1f5f9;color:#64748b;padding:1px 7px;border-radius:99px;font-size:.65rem;font-weight:700">{{ m.status | capitalize }}</span>
            @end
          </div>
          <div style="font-weight:700;font-size:.85rem;color:#0f172a">{{ m.titulo || m.ementa }}</div>
          <div style="font-size:.73rem;color:#64748b;margin-top:2px">{{ m.tipo }}@if(m.numero) · {{ m.numero }}@end</div>
          @if(m.status === 'aprovada' || m.status === 'rejeitada')
            <div style="display:flex;gap:10px;margin-top:5px;font-size:.73rem">
              <span style="color:#16a34a;font-weight:600"><i class="bi bi-hand-thumbs-up-fill"></i> {{ m.votos_sim||0 }}</span>
              <span style="color:#dc2626;font-weight:600"><i class="bi bi-hand-thumbs-down-fill"></i> {{ m.votos_nao||0 }}</span>
            </div>
          @end
        </div>
      </div>
      @end
    </div>
  @else
    <div style="text-align:center;padding:32px;color:#94a3b8">
      <i class="bi bi-file-earmark-x" style="font-size:2.5rem;display:block;margin-bottom:10px"></i>
      <div style="font-weight:700">Nenhuma matéria na pauta</div>
    </div>
  @end
</div>

{{-- SCREEN: PERFIL --}}
<div id="screen-perfil" class="screen">
  <div class="card card-pad">
    <div style="display:flex;align-items:center;gap:14px;margin-bottom:18px">
      <div style="width:60px;height:60px;border-radius:14px;background:var(--p-light);color:var(--p);display:flex;align-items:center;justify-content:center;font-weight:800;font-size:1.4rem">
        {{ (vereador?.nome_parlamentar || 'V').substring(0,1).toUpperCase() }}
      </div>
      <div>
        <div style="font-weight:800;font-size:1rem;color:#0f172a">{{ vereador?.nome_parlamentar }}</div>
        <div style="font-size:.8rem;color:#64748b">{{ vereador?.cargo }} · {{ vereador?.partido_sigla }}</div>
        <div style="font-size:.75rem;color:#94a3b8;margin-top:2px">{{ municipio?.nome }}</div>
      </div>
    </div>
    <a href="/logout" style="display:flex;align-items:center;justify-content:center;gap:8px;width:100%;padding:12px;background:#fee2e2;color:#dc2626;border:none;border-radius:10px;font-weight:700;text-decoration:none;font-size:.88rem">
      <i class="bi bi-box-arrow-right"></i>Sair
    </a>
  </div>
</div>

{{-- BOTTOM NAV --}}
<nav class="bottom-nav">
  <button class="nav-btn active" id="nav-home" onclick="showScreen('home')"><i class="bi bi-house-fill"></i>Início</button>
  <button class="nav-btn" id="nav-pauta" onclick="showScreen('pauta')"><i class="bi bi-list-ul"></i>Pauta</button>
  <button class="nav-btn" id="nav-perfil" onclick="showScreen('perfil')"><i class="bi bi-person-fill"></i>Perfil</button>
</nav>

<script>
const SESSAO_ID = {{ sessao?.id || 'null' }}
const VEREADOR_ID = {{ vereador?.id || 'null' }}

function showScreen(name){
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'))
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'))
  document.getElementById('screen-'+name).classList.add('active')
  document.getElementById('nav-'+name).classList.add('active')
}

async function confirmarPresenca(){
  if(!SESSAO_ID) return
  const r = await fetch('/app/votacao/quorum/presenca',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({sessao_id:SESSAO_ID})})
  if(r.ok) location.reload()
}

async function votar(opcao){
  const labels = {sim:'A FAVOR',nao:'CONTRA',abstencao:'Abstenção'}
  if(!confirm('Confirmar voto: '+labels[opcao]+'?')) return
  const r = await fetch('/app/votacao/votar',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({voto:opcao})})
  if(r.ok) location.reload()
  else { const e=await r.json(); alert(e.error||'Erro ao votar') }
}

async function pedirVoz(){
  if(!SESSAO_ID) return
  const tempo = document.getElementById('sel-tempo').value
  const r = await fetch('/app/votacao/voz/pedir',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({sessao_id:SESSAO_ID,tempo_minutos:parseInt(tempo)})})
  if(r.ok) location.reload()
}

async function cancelarVoz(){
  const r = await fetch('/app/votacao/voz/cancelar',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({sessao_id:SESSAO_ID})})
  if(r.ok) location.reload()
}

// Polling para sessões ativas
@if(sessao && votacaoAtiva && !meuVoto)
setInterval(()=>location.reload(), 8000)
@end
</script>
</body>
</html>
