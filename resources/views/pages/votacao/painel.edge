<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="refresh" content="10">
  <title>{{ configuracoes?.nome_camara || municipio?.nome || 'Câmara Municipal' }} — Painel TV</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Plus Jakarta Sans', sans-serif; box-sizing: border-box; }
    body { background: #0a0f1e; color: #e2e8f0; min-height: 100vh; margin: 0; display: flex; flex-direction: column; }

    /* Header */
    .painel-header { background: linear-gradient(135deg, #1e3a8a, #1d4ed8); padding: 1rem 2rem; display: flex; align-items: center; justify-content: space-between; border-bottom: 2px solid #3b82f6; }
    .painel-header h1 { font-size: 1.5rem; font-weight: 800; margin: 0; letter-spacing: -.5px; }
    .painel-header .brasao { font-size: 2rem; }
    .relogio { font-size: 1.8rem; font-weight: 700; color: #93c5fd; font-variant-numeric: tabular-nums; }

    /* Estado atual */
    .estado-badge { display: inline-flex; align-items: center; gap: .5rem; padding: .4rem 1.2rem; border-radius: 50px; font-size: .85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; }
    .estado-aguardando { background: #1e3a5f; color: #60a5fa; border: 1px solid #1d4ed8; }
    .estado-sessao { background: #14532d; color: #4ade80; border: 1px solid #16a34a; animation: pulsar 2s infinite; }
    .estado-votacao { background: #7c2d12; color: #fb923c; border: 1px solid #ea580c; animation: pulsar 1s infinite; }
    @keyframes pulsar { 0%,100% { opacity: 1; } 50% { opacity: .6; } }

    /* Main */
    .painel-main { flex: 1; display: flex; flex-direction: column; padding: 2rem; gap: 1.5rem; }

    /* Sessão info */
    .sessao-info { background: #1e293b; border: 1px solid #334155; border-radius: 16px; padding: 1.5rem 2rem; }
    .sessao-info h2 { font-size: 2rem; font-weight: 800; margin: 0 0 .25rem; color: #f1f5f9; }
    .sessao-info p { margin: 0; color: #94a3b8; font-size: 1rem; }

    /* Votação em andamento */
    .votacao-card { background: linear-gradient(135deg, #1c1917, #292524); border: 2px solid #f97316; border-radius: 16px; padding: 1.5rem 2rem; }
    .votacao-card h3 { color: #fb923c; font-weight: 800; font-size: 1.2rem; margin: 0 0 .5rem; }
    .votacao-card .ementa { font-size: 1.3rem; font-weight: 600; color: #f1f5f9; }
    .placar { display: flex; gap: 1rem; margin-top: 1rem; }
    .placar-item { flex: 1; border-radius: 12px; padding: 1rem; text-align: center; }
    .placar-sim { background: #14532d; border: 1px solid #16a34a; }
    .placar-nao { background: #450a0a; border: 1px solid #dc2626; }
    .placar-abs { background: #1c1917; border: 1px solid #78716c; }
    .placar-item .numero { font-size: 3rem; font-weight: 800; line-height: 1; }
    .placar-item .label { font-size: .75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; opacity: .7; margin-top: .25rem; }

    /* Vereadores presentes */
    .vereadores-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: .75rem; }
    .vereador-card { background: #1e293b; border: 1px solid #334155; border-radius: 12px; padding: .75rem 1rem; display: flex; align-items: center; gap: .75rem; }
    .vereador-card.presente { border-color: #16a34a; background: #0f2d1a; }
    .vereador-card.ausente { opacity: .4; }
    .vereador-foto { width: 40px; height: 40px; border-radius: 50%; object-fit: cover; background: #334155; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 1.2rem; }
    .vereador-nome { font-size: .8rem; font-weight: 600; line-height: 1.2; }
    .vereador-partido { font-size: .7rem; color: #64748b; }

    /* Footer */
    .painel-footer { background: #111827; border-top: 1px solid #1f2937; padding: .75rem 2rem; display: flex; align-items: center; justify-content: space-between; font-size: .8rem; color: #475569; }

    /* Standby */
    .standby { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; }
    .standby .logo { font-size: 5rem; margin-bottom: 1rem; }
    .standby h2 { font-size: 2.5rem; font-weight: 800; color: #1d4ed8; margin: 0 0 .5rem; }
    .standby p { color: #475569; font-size: 1.1rem; }
  </style>
</head>
<body>

{{-- Header sempre visível --}}
<div class="painel-header">
  <div class="d-flex align-items-center gap-3">
    <span class="brasao">🏛️</span>
    <div>
      <h1>{{ configuracoes?.nome_camara || municipio?.nome || 'Câmara Municipal' }}</h1>
      <small style="color:#93c5fd;font-size:.85rem">{{ municipio?.nome || '' }} — {{ municipio?.uf || '' }}</small>
    </div>
  </div>
  <div class="d-flex align-items-center gap-3">
    @if(sessao)
      <span class="estado-badge estado-sessao"><i class="bi bi-record-circle-fill"></i>Sessão em Andamento</span>
    @else
      <span class="estado-badge estado-aguardando"><i class="bi bi-clock"></i>Aguardando</span>
    @end
    <div class="relogio" id="relogio">--:--:--</div>
  </div>
</div>

@if(sessao)
  {{-- SESSÃO ATIVA --}}
  <div class="painel-main">
    <div class="sessao-info">
      <div class="d-flex align-items-center gap-3 mb-2">
        <span class="badge bg-primary">{{ sessao.tipo | capitalize }}</span>
        <span class="text-secondary small">{{ sessao.data_sessao }}</span>
        @if(sessao.local_)
          <span class="text-secondary small"><i class="bi bi-geo-alt me-1"></i>{{ sessao.local_ }}</span>
        @end
      </div>
      <h2>{{ sessao.descricao || 'Sessão Plenária' }}</h2>
    </div>

    @if(votacaoAtiva)
      {{-- VOTAÇÃO EM ANDAMENTO --}}
      <div class="votacao-card">
        <h3><i class="bi bi-broadcast me-2"></i>Votação em Andamento</h3>
        <div class="ementa">{{ votacaoAtiva.ementa || votacaoAtiva.tipo }}</div>
        <div class="placar">
          <div class="placar-item placar-sim">
            <div class="numero text-success">{{ votacaoAtiva.votos_sim || 0 }}</div>
            <div class="label text-success">Sim</div>
          </div>
          <div class="placar-item placar-nao">
            <div class="numero text-danger">{{ votacaoAtiva.votos_nao || 0 }}</div>
            <div class="label text-danger">Não</div>
          </div>
          <div class="placar-item placar-abs">
            <div class="numero text-secondary">{{ votacaoAtiva.votos_abstencao || 0 }}</div>
            <div class="label text-secondary">Abstenção</div>
          </div>
        </div>
      </div>
    @end

    @if(vereadores && vereadores.length)
      <div>
        <h6 class="text-secondary mb-2 small text-uppercase" style="letter-spacing:1px">
          <i class="bi bi-people me-1"></i>Vereadores ({{ presentes }}/{{ vereadores.length }} presentes)
        </h6>
        <div class="vereadores-grid">
          @each(v in vereadores)
            <div class="vereador-card {{ presencasIds && presencasIds.includes(v.id) ? 'presente' : 'ausente' }}">
              <div class="vereador-foto">
                @if(v.foto_url)
                  <img src="{{ v.foto_url }}" alt="{{ v.nome_parlamentar }}" style="width:40px;height:40px;border-radius:50%;object-fit:cover">
                @else
                  👤
                @end
              </div>
              <div>
                <div class="vereador-nome">{{ v.nome_parlamentar || v.nome }}</div>
                <div class="vereador-partido">{{ v.partido_sigla || '' }}</div>
              </div>
            </div>
          @end
        </div>
      </div>
    @end
  </div>

@else
  {{-- STANDBY --}}
  <div class="standby">
    <div class="logo">🏛️</div>
    <h2>VotaLegis</h2>
    <p>{{ configuracoes?.nome_camara || municipio?.nome || 'Câmara Municipal' }}</p>
    <p class="mt-2" style="color:#64748b">Aguardando início da sessão</p>
  </div>
@end

<div class="painel-footer">
  <span>VotaLegis — Sistema de Votação Eletrônica Legislativa</span>
  <span id="data-footer"></span>
</div>

<script>
function tick() {
  const now = new Date()
  const r = document.getElementById('relogio')
  if (r) r.textContent = now.toLocaleTimeString('pt-BR')
  const d = document.getElementById('data-footer')
  if (d) d.textContent = now.toLocaleDateString('pt-BR', { weekday:'long', year:'numeric', month:'long', day:'numeric' })
}
tick()
setInterval(tick, 1000)
</script>
</body>
</html>
