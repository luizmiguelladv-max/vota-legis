        <button class="btn-close-modal" onclick="fecharModal('novoVereador')"><i class="bi bi-x-lg"></i></button>
      </div>
      <div class="modal-body">
        <div class="form-group"><label>Nome completo *</label><input id="nv-nome" class="form-input" placeholder="Ex: João da Silva"></div>
        <div class="form-group"><label>Nome parlamentar *</label><input id="nv-nome-parl" class="form-input" placeholder="Ex: João Silva"></div>
        <div class="form-row">
          <div class="form-group">
            <label>Cargo *</label>
            <select id="nv-cargo" class="form-input">
