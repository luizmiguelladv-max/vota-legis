        <div class="form-row">
          <div class="form-group"><label>CPF</label><input id="nv-cpf" class="form-input" placeholder="000.000.000-00"></div>
          <div class="form-group"><label>E-mail</label><input id="nv-email" class="form-input" type="email" placeholder="email@camara.leg.br"></div>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn-ghost" onclick="fecharModal('novoVereador')">Cancelar</button>
        <button class="btn-primary" onclick="criarVereador()"><i class="bi bi-person-plus-fill"></i>Salvar</button>
      </div>
    </div>
  </div>

  {{-- MODAL EDITAR VEREADOR --}}
  <div id="modal-editarVereador" class="modal-overlay">
    <div class="modal-box" style="max-width:400px">
      <div class="modal-header">
        <div><div class="modal-title">Editar Vereador</div></div>
        <button class="btn-close-modal" onclick="fecharModal('editarVereador')"><i class="bi bi-x-lg"></i></button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="ev-id">
        <div class="form-group"><label>Nome parlamentar</label><input id="ev-nome" class="form-input"></div>
        <div class="form-group">
          <label>Cargo</label>
          <select id="ev-cargo" class="form-input">
            <option value="vereador">Vereador(a)</option>
            <option value="presidente">Presidente</option>
            <option value="vice-presidente">Vice-Presidente</option>
            <option value="secretario">Secretário(a)</option>
          </select>
        </div>
        <div class="form-group">
          <label>Partido</label>
          <select id="ev-partido" class="form-input">
            <option value="">-- Sem partido --</option>
            @each(p in partidos)
              <option value="{{ p.id }}">{{ p.sigla }} – {{ p.nome }}</option>
            @end
          </select>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn-ghost" onclick="fecharModal('editarVereador')">Cancelar</button>
        <button class="btn-primary" onclick="salvarVereador()"><i class="bi bi-check-lg"></i>Salvar</button>
      </div>
    </div>
  </div>
  @end

  @slot('scripts')
  <script>
  document.querySelectorAll('.modal-overlay').forEach(m =>
    m.addEventListener('click', e => { if(e.target===m) m.classList.remove('open') })
  )
  function fecharModal(id){ document.getElementById('modal-'+id).classList.remove('open') }
  function filtrarV(q){ document.querySelectorAll('#grid-vereadores .vereador-card').forEach(el=>{ el.style.display=el.dataset.busca.includes(q.toLowerCase())?'':'none' }) }

  async function criarVereador(){
    const r = await fetch('/controle/votacao/vereadores',{
      method:'POST', headers:{'Content-Type':'application/json'},
      body:JSON.stringify({ nome:document.getElementById('nv-nome').value, nome_parlamentar:document.getElementById('nv-nome-parl').value, cargo:document.getElementById('nv-cargo').value, partido_id:document.getElementById('nv-partido').value||null, cpf:document.getElementById('nv-cpf').value, email:document.getElementById('nv-email').value })
    })
    if(r.ok){ fecharModal('novoVereador'); location.reload() }
    else { const e=await r.json(); alert(e.error||'Erro ao salvar') }
  }

  function editarVereador(id, nome, cargo, partidoId){
    document.getElementById('ev-id').value=id
    document.getElementById('ev-nome').value=nome
    document.getElementById('ev-cargo').value=cargo
    document.getElementById('ev-partido').value=partidoId||''
    document.getElementById('modal-editarVereador').classList.add('open')
  }

  async function salvarVereador(){
    const id = document.getElementById('ev-id').value
    const r = await fetch('/controle/votacao/vereadores/'+id,{
      method:'PUT', headers:{'Content-Type':'application/json'},
      body:JSON.stringify({ nome_parlamentar:document.getElementById('ev-nome').value, cargo:document.getElementById('ev-cargo').value, partido_id:document.getElementById('ev-partido').value||null })
    })
    if(r.ok){ fecharModal('editarVereador'); location.reload() }
  }

  async function acoDelete(url, msg){
    if(!confirm(msg)) return
    await fetch(url,{method:'DELETE'})
    location.reload()
  }
  </script>
  @end
@end
