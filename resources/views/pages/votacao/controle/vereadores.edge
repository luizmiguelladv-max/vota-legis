            <div class="vereador-av" style="background:{{ v.partido_cor ? (v.partido_cor+'22') : '#dbeafe' }};color:{{ v.partido_cor||'#1d4ed8' }};border:2px solid {{ v.partido_cor||'#1d4ed8' }}">
              {{ v.nome_parlamentar.substring(0,1).toUpperCase() }}
            </div>
            <div style="flex:1;min-width:0">
              <div class="vereador-name">{{ v.nome_parlamentar }}</div>
              <div class="vereador-cargo">{{ v.cargo }}</div>
              <div class="vereador-partido">
                <span class="partido-tag" style="background:{{ v.partido_cor ? (v.partido_cor+'22') : '#dbeafe' }};color:{{ v.partido_cor||'#1d4ed8' }}">{{ v.partido_sigla || 'SEM PARTIDO' }}</span>
              </div>
            </div>
            <div style="display:flex;gap:4px">
              <button class="btn-icon" onclick="editarVereador({{ v.id }},'{{ v.nome_parlamentar }}','{{ v.cargo }}','{{ v.partido_id }}')" title="Editar"><i class="bi bi-pencil"></i></button>
              <button class="btn-icon danger" onclick="acoDelete('/controle/votacao/vereadores/{{ v.id }}','Desativar este vereador?')" title="Remover"><i class="bi bi-person-dash"></i></button>
            </div>
          </div>
