          <button class="btn-primary" style="margin-top:14px" onclick="document.getElementById('modal-novoVereador').classList.add('open')"><i class="bi bi-person-plus-fill"></i>Novo Vereador</button>
        </div>
      @end
    </div>
  </div>

  {{-- MODAL NOVO VEREADOR --}}
