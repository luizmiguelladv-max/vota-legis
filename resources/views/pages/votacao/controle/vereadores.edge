      <div>
        <div class="vl-header-title">Vereadores</div>
        <div class="vl-header-meta"><span>{{ totalVereadores }} parlamentares · Legislatura ativa</span></div>
      </div>
      <div class="vl-header-actions">
        <button class="btn-header btn-header-primary" onclick="document.getElementById('modal-novoVereador').classList.add('open')">
          <i class="bi bi-person-plus-fill"></i>Novo Vereador
        </button>
      </div>
    </div>
  </div>

  <div class="vl-content fade-up">
    <div class="card">
      <div class="card-header-bar">
        <div><div class="card-title">Vereadores Cadastrados</div></div>
        <input class="form-input" style="width:220px" placeholder="Buscar..." oninput="filtrarV(this.value)">
      </div>
      @if(vereadores && vereadores.length)
        <div class="vereador-grid" id="grid-vereadores" style="padding:16px 20px">
          @each(v in vereadores)
