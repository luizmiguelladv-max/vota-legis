  {{-- MODAL NOVA MATÉRIA --}}
  <div id="modal-novaMateria" class="modal-overlay">
    <div class="modal-box" style="max-width:540px">
      <div class="modal-header">
        <div><div class="modal-title">Nova Matéria</div><div class="modal-subtitle">Adicionar à pauta</div></div>
        <button class="btn-close-modal" onclick="fecharModal('novaMateria')"><i class="bi bi-x-lg"></i></button>
      </div>
      <div class="modal-body">
        <div class="form-row">
          <div class="form-group">
            <label>Tipo *</label>
            <select id="nm-tipo" class="form-input">
              <option value="ata">Ata</option>
              <option value="requerimento">Requerimento</option>
              <option value="projeto_lei">Projeto de Lei</option>
              <option value="projeto_resolucao">Projeto de Resolução</option>
              <option value="moca">Moção</option>
              <option value="indicacao">Indicação</option>
            </select>
          </div>
          <div class="form-group"><label>Número</label><input id="nm-numero" class="form-input" placeholder="001/2026"></div>
        </div>
        <div class="form-group"><label>Título *</label><input id="nm-titulo" class="form-input" placeholder="Ex: Projeto de Lei nº 001/2026"></div>
        <div class="form-group"><label>Ementa</label><textarea id="nm-ementa" class="form-input" rows="3" placeholder="Descreva o conteúdo..."></textarea></div>
        <div class="form-group">
          <label>Autores</label>
          <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px">
            @each(v in vereadores)
            <label style="display:flex;align-items:center;gap:7px;padding:8px 10px;border:1.5px solid #e2e8f0;border-radius:9px;cursor:pointer;transition:all .15s">
              <input type="checkbox" name="autores" value="{{ v.id }}" style="accent-color:var(--p);width:14px;height:14px">
              <div class="vereador-av" style="width:26px;height:26px;border-radius:6px;font-size:.72rem;background:{{ v.partido_cor ? (v.partido_cor+'22') : '#dbeafe' }};color:{{ v.partido_cor||'#1d4ed8' }};border:1px solid {{ v.partido_cor||'#1d4ed8' }}">{{ v.nome_parlamentar.substring(0,1).toUpperCase() }}</div>
              <span style="font-size:.8rem;font-weight:600;color:#0f172a;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">{{ v.nome_parlamentar.split(' ')[0] }}</span>
            </label>
            @end
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn-ghost" onclick="fecharModal('novaMateria')">Cancelar</button>
        <button class="btn-primary" onclick="criarMateria()"><i class="bi bi-plus-lg"></i>Salvar Matéria</button>
      </div>
    </div>
  </div>

  {{-- MODAL TEMPO DE FALA --}}
  <div id="modal-tempoFala" class="modal-overlay">
    <div class="modal-box" style="max-width:500px">
      <div class="modal-header">
        <div><div class="modal-title">Tempo de Fala</div><div class="modal-subtitle">Gerenciar inscrições</div></div>
        <button class="btn-close-modal" onclick="fecharModal('tempoFala')"><i class="bi bi-x-lg"></i></button>
      </div>
      <div class="modal-body">
        {{-- FALANDO AGORA --}}
        @if(falando)
        <div style="background:linear-gradient(135deg,#f59e0b,#d97706);border-radius:14px;padding:18px;color:#fff;margin-bottom:4px">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px">
            <div style="display:flex;align-items:center;gap:10px">
              <div style="width:44px;height:44px;border-radius:10px;background:rgba(255,255,255,.25);display:flex;align-items:center;justify-content:center;font-weight:800;font-size:1rem">
                {{ falando.nome_parlamentar.substring(0,1).toUpperCase() }}
              </div>
              <div>
                <div style="font-weight:800">{{ falando.nome_parlamentar }}</div>
                <div style="font-size:.78rem;opacity:.8">{{ falando.cargo }}</div>
              </div>
            </div>
            <div style="text-align:right">
              <div class="timer-big" id="timer-display">{{ falando.tempo_minutos || 3 }}:00</div>
              <div style="font-size:.7rem;opacity:.7">restantes</div>
            </div>
          </div>
          <div style="display:flex;gap:8px">
            <button onclick="addMinuto()" style="background:rgba(255,255,255,.2);border:none;color:#fff;border-radius:8px;padding:7px 13px;font-size:.8rem;font-weight:600;cursor:pointer"><i class="bi bi-plus-lg"></i>+1 min</button>
            <button onclick="togglePause()" id="btn-pause" style="background:rgba(255,255,255,.2);border:none;color:#fff;border-radius:8px;padding:7px 13px;font-size:.8rem;font-weight:600;cursor:pointer"><i class="bi bi-pause-fill"></i>Pausar</button>
            <button onclick="acao('/controle/votacao/voz/{{ falando.id }}/cancelar','Encerrar fala?')" style="background:#dc2626;border:none;color:#fff;border-radius:8px;padding:7px 13px;font-size:.8rem;font-weight:700;cursor:pointer;margin-left:auto"><i class="bi bi-x-lg"></i>Encerrar</button>
          </div>
        </div>
        @end

        {{-- FILA --}}
        @if(filaFala && filaFala.length)
        <div>
          <div style="font-size:.75rem;font-weight:700;color:#475569;text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px">Fila</div>
          @each(f in filaFala)
          <div style="display:flex;align-items:center;gap:10px;background:#f8fafc;border-radius:9px;padding:10px 12px;margin-bottom:6px">
            <span style="width:26px;height:26px;background:#e2e8f0;color:#475569;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:.75rem;font-weight:700;flex-shrink:0">{{ loop.index + 1 }}</span>
            <div style="flex:1;min-width:0">
              <div style="font-weight:600;font-size:.83rem;color:#0f172a">{{ f.nome_parlamentar }}</div>
              <div style="font-size:.7rem;color:#64748b">{{ f.tempo_minutos || 3 }} minutos</div>
            </div>
            <button class="btn-primary btn-sm" onclick="acao('/controle/votacao/voz/{{ f.id }}/conceder','Conceder a voz?')">Iniciar</button>
            <button class="btn-icon danger" onclick="acao('/controle/votacao/voz/{{ f.id }}/cancelar','Remover da fila?')"><i class="bi bi-x-lg"></i></button>
          </div>
          @end
        </div>
        @end

        {{-- ADICIONAR --}}
        <div style="border-top:1px solid #f1f5f9;padding-top:12px">
          <div style="font-size:.75rem;font-weight:700;color:#475569;text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px">Adicionar à fila</div>
          <div style="display:flex;gap:8px">
            <select id="fala-vereador" class="form-input" style="flex:1">
              <option value="">Selecione o vereador...</option>
              @each(v in vereadores)
                <option value="{{ v.id }}">{{ v.nome_parlamentar }}</option>
              @end
            </select>
            <select id="fala-tempo" class="form-input" style="width:100px">
              <option value="3">3 min</option>
              <option value="5">5 min</option>
              <option value="10">10 min</option>
              <option value="15">15 min</option>
            </select>
            <button class="btn-primary" onclick="adicionarFila()">Adicionar</button>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn-ghost" onclick="fecharModal('tempoFala')">Fechar</button>
      </div>
    </div>
  </div>

  {{-- MODAL COMUNICADO --}}
  <div id="modal-comunicado" class="modal-overlay">
    <div class="modal-box" style="max-width:420px">
      <div class="modal-header">
        <div><div class="modal-title">Comunicado</div><div class="modal-subtitle">Exibir no Painel TV</div></div>
        <button class="btn-close-modal" onclick="fecharModal('comunicado')"><i class="bi bi-x-lg"></i></button>
      </div>
      <div class="modal-body">
        <div class="form-group"><label>Título</label><input id="com-titulo" class="form-input" placeholder="Atenção"></div>
        <div class="form-group"><label>Mensagem</label><textarea id="com-msg" class="form-input" rows="4" placeholder="Mensagem para o painel..."></textarea></div>
      </div>
      <div class="modal-footer">
        <button class="btn-ghost" onclick="fecharModal('comunicado')">Cancelar</button>
        <button class="btn-primary" onclick="enviarComunicado()"><i class="bi bi-megaphone-fill"></i>Enviar</button>
      </div>
    </div>
  </div>
  @end

  @slot('scripts')
  <script>
  const SESSAO_ID = {{ sessao.id }}

  document.querySelectorAll('.modal-overlay').forEach(m =>
    m.addEventListener('click', e => { if(e.target===m) m.classList.remove('open') })
  )
  function fecharModal(id){ document.getElementById('modal-'+id).classList.remove('open') }

  async function acao(url, msg, method='POST'){
    if(!confirm(msg)) return
    await fetch(url, {method})
    location.reload()
  }

  async function abrirVotacao(materiaId, secreta){
    if(!confirm(secreta?'Iniciar votação SECRETA?':'Iniciar votação nominal?')) return
    const r = await fetch('/controle/votacao/materias/'+materiaId+'/votacao/abrir',{
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ sessao_id: SESSAO_ID, tipo_votacao: secreta?'secreta':'nominal' })
    })
    if(r.ok) location.reload()
    else { const e=await r.json(); alert(e.error||'Erro') }
  }

  async function criarMateria(){
    const autores = [...document.querySelectorAll('input[name="autores"]:checked')].map(c=>c.value)
    const r = await fetch('/controle/votacao/materias',{
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        sessao_id: SESSAO_ID,
        tipo: document.getElementById('nm-tipo').value,
        numero: document.getElementById('nm-numero').value,
        titulo: document.getElementById('nm-titulo').value,
        ementa: document.getElementById('nm-ementa').value,
        autores,
      })
    })
    if(r.ok){ fecharModal('novaMateria'); location.reload() }
    else { const e=await r.json(); alert(e.error||'Erro') }
  }

  async function togglePresenca(vereadorId, sessaoId, status){
    await fetch('/controle/votacao/quorum/presenca',{
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ vereador_id: vereadorId, sessao_id: sessaoId, status })
    })
    location.reload()
  }

  async function adicionarFila(){
    const v = document.getElementById('fala-vereador').value
    if(!v) return alert('Selecione um vereador')
    await fetch('/controle/votacao/voz/timer',{
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ vereador_id:v, sessao_id:SESSAO_ID, tempo_minutos:parseInt(document.getElementById('fala-tempo').value) })
    })
    location.reload()
  }

  async function enviarComunicado(){
    // TODO: integrar SSE
    alert('Comunicado: ' + document.getElementById('com-titulo').value)
    fecharModal('comunicado')
  }

  // Timer de fala
  @if(falando)
  let timerSecs = {{ (falando.tempo_minutos || 3) * 60 }}, pausado = false
  function renderTimer(){ const m=String(Math.floor(timerSecs/60)).padStart(2,'0'), s=String(timerSecs%60).padStart(2,'0'); document.getElementById('timer-display').textContent=m+':'+s }
  setInterval(()=>{ if(!pausado && timerSecs>0){ timerSecs--; renderTimer() } }, 1000)
  let addMin=()=>{ timerSecs+=60; renderTimer() }
  function togglePause(){
    pausado=!pausado
    document.getElementById('btn-pause').innerHTML = pausado ? '<i class="bi bi-play-fill"></i>Retomar' : '<i class="bi bi-pause-fill"></i>Pausar'
  }
  @end

  // Polling placar em votação
  @if(votacaoAtiva)
  setInterval(async()=>{
    const r = await fetch('/controle/votacao/events/{{ sessao.id }}')
    if(!r.ok) return
    // TODO: consumir SSE para atualizar placar
  }, 3000)
  @end
  </script>
  @end
@end
