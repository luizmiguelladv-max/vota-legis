      </div>
      <div class="modal-body">
        <div class="quorum-grid">
          @each(v in vereadores)
          <div class="quorum-card {{ presencasMap[v.id] === 'presente' ? 'quorum-presente' : presencasMap[v.id] === 'justificado' ? 'quorum-aj' : 'quorum-ausente' }}">
            <div class="quorum-av" style="background:{{ v.partido_cor ? (v.partido_cor + '22') : '#dbeafe' }};color:{{ v.partido_cor || '#1d4ed8' }};border:2px solid {{ v.partido_cor || '#1d4ed8' }}">
              {{ v.nome_parlamentar.substring(0,1).toUpperCase() }}
