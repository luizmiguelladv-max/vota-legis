                <button class="btn-primary btn-sm" style="background:linear-gradient(135deg,#22c55e,#16a34a)" onclick="acao('/controle/votacao/materias/{{ m.id }}/votacao/encerrar','Encerrar votação e apurar resultado?')"><i class="bi bi-check-circle-fill"></i>Encerrar Votação</button>
                <button class="btn-ghost btn-sm" onclick="acao('/controle/votacao/materias/{{ m.id }}/votacao/encerrar','Cancelar votação?')"><i class="bi bi-x-lg"></i>Cancelar</button>
