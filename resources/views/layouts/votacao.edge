  <style>
    body { background: #0f172a; color: #e2e8f0; min-height: 100vh; font-family: system-ui, sans-serif; }
    .sidebar { width: 240px; background: #1e293b; border-right: 1px solid #334155; min-height: 100vh; position: fixed; top: 0; left: 0; z-index: 100; }
    .brand { padding: 1.25rem 1rem; border-bottom: 1px solid #334155; }
    .brand h5 { color: #60a5fa; font-weight: 700; margin: 0; }
    .brand small { color: #64748b; font-size: .7rem; }
    .nav-link { color: #94a3b8; padding: .45rem 1rem; border-radius: 8px; margin: 2px 8px; font-size: .875rem; display: flex; align-items: center; gap: 8px; }
    .nav-link:hover, .nav-link.active { background: #1d4ed8; color: #fff; }
    .nav-label { color: #475569; font-size: .65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; padding: .75rem 1.5rem .25rem; }
    .main { margin-left: 240px; padding: 1.5rem; }
    .topbar { background: #1e293b; border-bottom: 1px solid #334155; padding: .75rem 1.5rem; margin: -1.5rem -1.5rem 1.5rem; display: flex; align-items: center; justify-content: space-between; }
    .card { background: #1e293b; border: 1px solid #334155; border-radius: 12px; }
    .card-header { background: transparent; border-bottom: 1px solid #334155; }
    .form-control, .form-select { background: #0f172a; border-color: #334155; color: #e2e8f0; }
    .form-control:focus, .form-select:focus { background: #0f172a; border-color: #1d4ed8; color: #e2e8f0; box-shadow: 0 0 0 .2rem rgba(29,78,216,.25); }
    .modal-content { background: #1e293b; border: 1px solid #334155; }
    .modal-header, .modal-footer { border-color: #334155; }
    .table { color: #cbd5e1; }
    .table thead th { color: #64748b; font-size: .75rem; text-transform: uppercase; border-color: #334155; }
    .table td { border-color: #1e293b; }
    .user-box { position: absolute; bottom: 0; width: 100%; padding: 1rem; border-top: 1px solid #334155; }
  </style>
  @yield('styles')
</head>
