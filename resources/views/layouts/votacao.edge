<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ pageTitle || 'VotaLegis' }}</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --p:#2563eb; --p-dark:#1d4ed8; --p-light:#dbeafe; --p-rgb:37,99,235;
      --sb:#0f172a; --sb-w:260px;
      --font:'Plus Jakarta Sans',system-ui,sans-serif;
      --mono:'JetBrains Mono',monospace;
    }
    *{box-sizing:border-box;margin:0;padding:0;font-family:var(--font)}
    body{background:#f1f5f9;min-height:100vh;display:flex}
    ::-webkit-scrollbar{width:5px;height:5px}
    ::-webkit-scrollbar-thumb{background:#334155;border-radius:4px}

    /* SIDEBAR */
    .vl-sidebar{
      width:var(--sb-w);background:var(--sb);display:flex;flex-direction:column;
      flex-shrink:0;position:fixed;top:0;left:0;height:100vh;
      box-shadow:4px 0 20px rgba(0,0,0,.25);z-index:100
    }
    .vl-brand{padding:18px 16px;border-bottom:1px solid rgba(255,255,255,.06);display:flex;align-items:center;gap:12px}
    .vl-brand-icon{width:44px;height:44px;border-radius:11px;background:rgba(255,255,255,.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:1.3rem;color:#fff}
    .vl-brand-name{font-weight:800;font-size:.95rem;color:#f8fafc;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .vl-brand-sub{font-size:.7rem;color:#475569;margin-top:1px}
    .vl-online{display:flex;align-items:center;gap:5px;margin-top:5px}
    .vl-online-dot{width:6px;height:6px;background:#22c55e;border-radius:50%}
    .vl-online-txt{font-size:.68rem;color:#22c55e;font-weight:600}

    .vl-stats{display:grid;grid-template-columns:repeat(3,1fr);padding:12px 16px;border-bottom:1px solid rgba(255,255,255,.06);gap:6px;text-align:center}
    .vl-stat-n{font-size:1.2rem;font-weight:800;color:#f1f5f9;font-family:var(--mono)}
    .vl-stat-l{font-size:.62rem;color:#475569;text-transform:uppercase;letter-spacing:.05em;margin-top:1px}

    .vl-nav{flex:1;overflow-y:auto;padding:6px 0}
    .nav-section{font-size:.63rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:#334155;padding:14px 20px 5px}
    .nav-link{
      display:flex;align-items:center;gap:11px;padding:9px 16px;margin:1px 10px;
      border-radius:9px;color:#64748b;text-decoration:none;
      transition:background .15s,color .15s;position:relative;font-size:.875rem;font-weight:500
    }
    .nav-link:hover{background:rgba(255,255,255,.06);color:#e2e8f0}
    .nav-link.active{background:rgba(var(--p-rgb),.2);color:#fff}
    .nav-link.active::before{content:'';position:absolute;left:-10px;top:50%;transform:translateY(-50%);width:3px;height:55%;background:var(--p);border-radius:0 3px 3px 0}
    .nav-icon{width:32px;height:32px;border-radius:8px;background:rgba(255,255,255,.06);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:.95rem;transition:background .15s}
    .nav-link.active .nav-icon{background:var(--p)}
    .nav-badge{margin-left:auto;background:var(--p);color:#fff;font-size:.62rem;font-weight:700;padding:2px 7px;border-radius:99px}

    .vl-user{padding:14px 16px;border-top:1px solid rgba(255,255,255,.06);display:flex;align-items:center;gap:10px}
    .vl-user-av{width:36px;height:36px;border-radius:9px;background:linear-gradient(135deg,var(--p),var(--p-dark));display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:.82rem;flex-shrink:0;position:relative}
    .vl-user-dot{position:absolute;bottom:-1px;right:-1px;width:10px;height:10px;background:#22c55e;border:2px solid var(--sb);border-radius:50%}
    .vl-user-name{font-weight:600;font-size:.8rem;color:#f1f5f9;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .vl-user-role{font-size:.68rem;color:#475569}
    .vl-logout{margin-left:auto;background:transparent;border:none;cursor:pointer;padding:6px;border-radius:7px;color:#475569;flex-shrink:0;font-size:.95rem;transition:color .15s,background .15s}
    .vl-logout:hover{color:#ef4444;background:rgba(239,68,68,.1)}

    /* MAIN */
    .vl-main{margin-left:var(--sb-w);flex:1;display:flex;flex-direction:column;min-height:100vh;overflow-x:hidden}

    /* HEADER */
    .vl-header{
      background:linear-gradient(135deg,var(--p) 0%,var(--p-dark) 100%);
      color:#fff;padding:20px 28px;position:relative;overflow:hidden
    }
    .vl-header::before{content:'';position:absolute;top:-50%;right:-8%;width:380px;height:380px;background:rgba(255,255,255,.05);border-radius:50%}
    .vl-header::after{content:'';position:absolute;bottom:-70%;left:-3%;width:280px;height:280px;background:rgba(255,255,255,.04);border-radius:50%}
    .vl-header-inner{position:relative;display:flex;align-items:center;justify-content:space-between;gap:16px}
    .vl-header-title{font-size:1.3rem;font-weight:800;letter-spacing:-.02em}
    .vl-header-meta{display:flex;align-items:center;gap:14px;margin-top:4px;opacity:.7;font-size:.78rem}
    .vl-header-meta span{display:flex;align-items:center;gap:4px}
    .vl-header-actions{display:flex;align-items:center;gap:8px}
    .btn-header{display:flex;align-items:center;gap:6px;background:rgba(255,255,255,.14);border:none;color:#fff;padding:8px 14px;border-radius:9px;font-size:.8rem;font-weight:600;cursor:pointer;text-decoration:none;white-space:nowrap;transition:background .15s}
    .btn-header:hover{background:rgba(255,255,255,.24)}
    .btn-header-primary{background:rgba(255,255,255,.9);color:var(--p);font-weight:700}
    .btn-header-primary:hover{background:#fff;color:var(--p-dark)}
    .live-badge{display:flex;align-items:center;gap:7px;background:rgba(255,255,255,.14);padding:7px 14px;border-radius:99px;font-size:.78rem;font-weight:600;backdrop-filter:blur(6px)}

    /* CONTENT */
    .vl-content{flex:1;padding:24px 28px;display:flex;flex-direction:column;gap:20px}

    /* CARDS */
    .card{background:#fff;border-radius:14px;border:1px solid #e2e8f0;transition:transform .2s,box-shadow .2s}
    .card:hover{transform:translateY(-1px);box-shadow:0 8px 28px -6px rgba(15,23,42,.1)}
    .card-pad{padding:20px}
    .card-header-bar{padding:14px 20px;border-bottom:1px solid #f1f5f9;display:flex;align-items:center;justify-content:space-between}
    .card-title{font-weight:700;font-size:.9rem;color:#0f172a}
    .card-subtitle{font-size:.75rem;color:#64748b;margin-top:2px}

    /* STATS */
    .stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
    .stat-card{background:#fff;border-radius:14px;border:1px solid #e2e8f0;padding:18px 20px;display:flex;align-items:center;gap:14px}
    .stat-card.primary{background:linear-gradient(135deg,var(--p),var(--p-dark));border:none;color:#fff}
    .stat-icon{width:46px;height:46px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.25rem;flex-shrink:0}
    .stat-icon.si-white{background:rgba(255,255,255,.2);color:#fff}
    .stat-icon.si-blue{background:#dbeafe;color:#2563eb}
    .stat-icon.si-purple{background:#ede9fe;color:#7c3aed}
    .stat-icon.si-green{background:#dcfce7;color:#16a34a}
    .stat-icon.si-amber{background:#fef3c7;color:#d97706}
    .stat-n{font-size:1.9rem;font-weight:800;font-family:var(--mono);line-height:1}
    .stat-l{font-size:.75rem;margin-top:3px;opacity:.75}
    .stat-card:not(.primary) .stat-l{color:#64748b}
    .stat-card:not(.primary) .stat-n{color:#0f172a}

    /* BUTTONS */
    .btn-primary{background:linear-gradient(135deg,var(--p),var(--p-dark));color:#fff;border:none;border-radius:9px;padding:9px 18px;font-size:.85rem;font-weight:700;cursor:pointer;display:inline-flex;align-items:center;gap:6px;transition:filter .15s,transform .15s;text-decoration:none}
    .btn-primary:hover{filter:brightness(1.08);transform:translateY(-1px)}
    .btn-ghost{background:#fff;color:#475569;border:1.5px solid #e2e8f0;border-radius:9px;padding:8px 16px;font-size:.83rem;font-weight:600;cursor:pointer;display:inline-flex;align-items:center;gap:6px;transition:background .15s,border-color .15s;text-decoration:none}
    .btn-ghost:hover{background:#f8fafc;border-color:#cbd5e1}
    .btn-danger{background:#ef4444;color:#fff;border:none;border-radius:9px;padding:8px 16px;font-size:.83rem;font-weight:700;cursor:pointer;display:inline-flex;align-items:center;gap:6px;transition:filter .15s}
    .btn-danger:hover{filter:brightness(1.08)}
    .btn-icon{background:#fff;color:#475569;border:1.5px solid #e2e8f0;border-radius:8px;padding:7px 9px;font-size:.9rem;cursor:pointer;line-height:1;transition:background .15s;display:inline-flex;align-items:center}
    .btn-icon:hover{background:#f8fafc}
    .btn-icon.danger:hover{background:#fef2f2;border-color:#fecaca;color:#ef4444}
    .btn-sm{padding:6px 12px;font-size:.78rem;border-radius:7px}

    /* BADGES */
    .badge-live{display:inline-flex;align-items:center;gap:5px;background:var(--p);color:#fff;padding:3px 10px;border-radius:99px;font-size:.72rem;font-weight:700}
    .badge-agendada{display:inline-flex;align-items:center;gap:5px;background:#dbeafe;color:#1d4ed8;padding:3px 10px;border-radius:99px;font-size:.72rem;font-weight:700}
    .badge-encerrada{display:inline-flex;align-items:center;gap:5px;background:#f1f5f9;color:#64748b;padding:3px 10px;border-radius:99px;font-size:.72rem;font-weight:700}
    .badge-aprovada{display:inline-flex;align-items:center;gap:5px;background:#dcfce7;color:#15803d;padding:3px 10px;border-radius:99px;font-size:.72rem;font-weight:700}
    .badge-rejeitada{display:inline-flex;align-items:center;gap:5px;background:#fee2e2;color:#b91c1c;padding:3px 10px;border-radius:99px;font-size:.72rem;font-weight:700}

    /* LIVE DOT */
    @keyframes pulseRing{0%{transform:scale(.85);opacity:1}100%{transform:scale(2.2);opacity:0}}
    .live-dot{position:relative;display:inline-flex;width:8px;height:8px;flex-shrink:0}
    .live-dot::before{content:'';position:absolute;inset:0;border-radius:50%;background:#22c55e;animation:pulseRing 1.5s infinite}
    .live-dot::after{content:'';position:absolute;inset:0;border-radius:50%;background:#22c55e}

    /* SESSAO ITEM */
    .sessao-item{display:flex;border-bottom:1px solid #f8fafc;transition:background .15s}
    .sessao-item:last-child{border-bottom:none}
    .sessao-item:hover{background:#fafafa}
    .sessao-stripe{width:4px;flex-shrink:0;border-radius:0 0 0 0}
    .stripe-live{background:var(--p)}
    .stripe-agendada{background:#60a5fa}
    .stripe-encerrada{background:#cbd5e1}
    .sessao-body{flex:1;padding:16px 20px;display:flex;align-items:center;justify-content:space-between;gap:16px}
    .sessao-title{font-weight:700;font-size:.92rem;color:#0f172a;margin:5px 0}
    .sessao-meta{display:flex;align-items:center;gap:14px;font-size:.78rem;color:#64748b}
    .sessao-meta span{display:flex;align-items:center;gap:4px}

    /* SESSAO LIVE BAR */
    .live-bar{background:linear-gradient(135deg,#1e3a8a,#1d4ed8);color:#fff;padding:12px 28px;display:flex;align-items:center;justify-content:space-between;gap:12px}

    /* VEREADOR CARD */
    .vereador-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
    .vereador-card{background:#fff;border:1px solid #e2e8f0;border-radius:12px;padding:16px;display:flex;align-items:center;gap:12px;transition:transform .15s,box-shadow .15s}
    .vereador-card:hover{transform:translateY(-1px);box-shadow:0 6px 20px -4px rgba(15,23,42,.1)}
    .vereador-av{width:48px;height:48px;border-radius:11px;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:1.1rem;flex-shrink:0}
    .vereador-name{font-weight:700;font-size:.88rem;color:#0f172a}
    .vereador-cargo{font-size:.73rem;color:#64748b;margin-top:1px}
    .vereador-partido{margin-top:6px}
    .partido-tag{display:inline-block;padding:2px 8px;border-radius:5px;font-size:.68rem;font-weight:700}

    /* QUORUM CARDS */
    .quorum-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
    .quorum-card{border-radius:11px;padding:12px 14px;display:flex;align-items:center;gap:10px}
    .quorum-presente{background:linear-gradient(135deg,#f0fdf4,#dcfce7);border:2px solid #86efac}
    .quorum-ausente{background:#f8fafc;border:2px solid #e2e8f0;opacity:.75}
    .quorum-aj{background:linear-gradient(135deg,#fffbeb,#fef3c7);border:2px solid #fcd34d}
    .quorum-av{width:40px;height:40px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.9rem;flex-shrink:0}

    /* PROGRESS */
    .progress-track{height:5px;background:#e2e8f0;border-radius:99px;overflow:hidden}
    .progress-fill{height:100%;background:linear-gradient(90deg,var(--p),var(--p-dark));border-radius:99px;transition:width .4s}

    /* MATERIA */
    .materia-row{padding:16px 20px;border-bottom:1px solid #f1f5f9;display:flex;gap:12px;transition:background .15s}
    .materia-row:last-child{border-bottom:none}
    .materia-row:hover{background:#fafafa}
    .materia-row.em-votacao{background:linear-gradient(90deg,#f0fdf4,transparent);border-left:4px solid #22c55e}
    .materia-row.em-leitura{background:linear-gradient(90deg,#fffbeb,transparent);border-left:4px solid #f59e0b}
    .materia-n{font-size:.78rem;font-weight:700;color:#94a3b8;font-family:var(--mono);white-space:nowrap;padding-top:2px}
    .materia-title{font-weight:700;font-size:.92rem;color:#0f172a;margin-bottom:5px}
    .materia-ementa{font-size:.8rem;color:#64748b;margin-bottom:10px}

    /* VOTACAO PLACAR */
    .placar{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin:10px 0}
    .placar-box{border-radius:10px;padding:10px;text-align:center;color:#fff}
    .placar-sim{background:linear-gradient(135deg,#22c55e,#16a34a)}
    .placar-nao{background:linear-gradient(135deg,#ef4444,#dc2626)}
    .placar-abs{background:linear-gradient(135deg,#06b6d4,#0891b2)}
    .placar-n{font-size:1.6rem;font-weight:800;font-family:var(--mono);line-height:1}
    .placar-l{font-size:.65rem;font-weight:700;opacity:.85;margin-top:2px}

    /* MODAL */
    .modal-overlay{position:fixed;inset:0;background:rgba(15,23,42,.6);backdrop-filter:blur(6px);display:none;align-items:center;justify-content:center;z-index:200}
    .modal-overlay.open{display:flex}
    .modal-box{background:#fff;border-radius:18px;width:100%;max-height:92vh;overflow-y:auto;box-shadow:0 24px 64px rgba(15,23,42,.2)}
    .modal-header{padding:18px 22px;border-bottom:1px solid #f1f5f9;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;background:#fff;z-index:1}
    .modal-title{font-weight:800;font-size:.95rem;color:#0f172a}
    .modal-subtitle{font-size:.78rem;color:#64748b;margin-top:2px}
    .modal-body{padding:20px 22px;display:flex;flex-direction:column;gap:14px}
    .modal-footer{padding:14px 22px;border-top:1px solid #f1f5f9;display:flex;justify-content:flex-end;gap:10px;background:#fafafa;border-radius:0 0 18px 18px}
    .btn-close-modal{background:#f8fafc;border:none;cursor:pointer;padding:7px;border-radius:8px;color:#64748b;font-size:1rem;line-height:1;transition:background .15s}
    .btn-close-modal:hover{background:#f1f5f9;color:#0f172a}

    /* FORMS */
    .form-group{display:flex;flex-direction:column;gap:5px}
    .form-group label{font-size:.8rem;font-weight:700;color:#0f172a}
    .form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
    .form-input{padding:9px 13px;border:1.5px solid #e2e8f0;border-radius:9px;font-size:.875rem;color:#0f172a;background:#fff;width:100%;font-family:var(--font);transition:border-color .15s,box-shadow .15s}
    .form-input:focus{outline:none;border-color:var(--p);box-shadow:0 0 0 3px rgba(var(--p-rgb),.12)}
    textarea.form-input{resize:vertical}

    /* TIMER */
    .timer-big{font-size:3.5rem;font-weight:800;font-family:var(--mono);line-height:1}

    /* ANIM */
    @keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
    .fade-up{animation:fadeUp .25s ease both}

    /* EMPTY STATE */
    .empty-state{display:flex;flex-direction:column;align-items:center;padding:48px 24px;text-align:center;color:#94a3b8}
    .empty-state i{font-size:3rem;margin-bottom:12px}
    .empty-state h5{color:#64748b;font-weight:700}
    .empty-state p{font-size:.83rem;margin-top:4px}

    /* TOOLTIP DE BARRA LATERAL DA SESSÃO */
    .subheader{background:#fff;border-bottom:1px solid #e2e8f0;padding:12px 28px;display:flex;align-items:center;justify-content:space-between;gap:12px;position:sticky;top:0;z-index:50}
    .subheader-title{font-weight:800;font-size:.95rem;color:#0f172a}
  </style>
</head>
<body>

<aside class="vl-sidebar">
  <div class="vl-brand">
    <div class="vl-brand-icon"><i class="bi bi-building-fill"></i></div>
    <div style="flex:1;min-width:0">
      <div class="vl-brand-name">{{ municipio?.nome || 'Câmara Municipal' }}</div>
      <div class="vl-brand-sub">{{ municipio?.uf || 'BR' }} · VotaLegis</div>
      <div class="vl-online"><div class="vl-online-dot"></div><span class="vl-online-txt">Online</span></div>
    </div>
  </div>
  <div class="vl-stats">
    <div><div class="vl-stat-n" style="color:var(--p)">{{ totalVereadores || 0 }}</div><div class="vl-stat-l">Vereadores</div></div>
    <div><div class="vl-stat-n">{{ totalSessoes || 0 }}</div><div class="vl-stat-l">Sessões</div></div>
    <div><div class="vl-stat-n">{{ totalMaterias || 0 }}</div><div class="vl-stat-l">Matérias</div></div>
  </div>
  <nav class="vl-nav">
    {{{ await $slots.sidebar() }}}
  </nav>
  <div class="vl-user">
    <div class="vl-user-av">
      {{ (usuario?.nome || 'U').substring(0,2).toUpperCase() }}
      <div class="vl-user-dot"></div>
    </div>
    <div style="flex:1;min-width:0">
      <div class="vl-user-name">{{ usuario?.nome || 'Usuário' }}</div>
      <div class="vl-user-role">{{ usuario?.perfil || 'Secretaria' }}</div>
    </div>
    <a href="/logout" class="vl-logout" title="Sair"><i class="bi bi-box-arrow-right"></i></a>
  </div>
</aside>

<div class="vl-main">
  {{{ await $slots.content() }}}
</div>

{{{ await $slots.scripts() }}}
</body>
</html>
