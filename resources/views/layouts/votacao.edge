<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>VotaLegis</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  <style>
    body { background: #0f172a; color: #e2e8f0; }
    .sidebar { width: 240px; background: #1e293b; border-right: 1px solid #334155; min-height: 100vh; position: fixed; top: 0; left: 0; }
    .sidebar-brand { padding: 1.25rem 1rem; border-bottom: 1px solid #334155; }
    .sidebar-brand h5 { color: #60a5fa; font-weight: 700; margin: 0; }
    .sidebar-brand small { color: #64748b; font-size: .7rem; }
    .nav-link { color: #94a3b8; padding: .5rem 1rem; border-radius: 8px; margin: 2px 8px; transition: all .2s; font-size: .875rem; display: block; text-decoration: none; }
    .nav-link:hover, .nav-link.active { background: #1d4ed8; color: #fff; }
    .nav-section { color: #475569; font-size: .65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; padding: .75rem 1.5rem .25rem; }
    .main-content { margin-left: 240px; padding: 1.5rem; }
    .card { background: #1e293b; border: 1px solid #334155; border-radius: 12px; }
    .table { color: #cbd5e1; }
    .table thead th { color: #64748b; font-size: .75rem; text-transform: uppercase; border-color: #334155; }
    .table td { border-color: #1e293b; }
    .form-control, .form-select { background: #0f172a; border-color: #334155; color: #e2e8f0; }
    .form-control:focus, .form-select:focus { background: #0f172a; border-color: #1d4ed8; color: #e2e8f0; box-shadow: 0 0 0 .2rem rgba(29,78,216,.25); }
    .modal-content { background: #1e293b; border: 1px solid #334155; }
    .modal-header, .modal-footer { border-color: #334155; }
  </style>
</head>
<body>
<div class="sidebar">
  <div class="sidebar-brand">
    <h5><i class="bi bi-building-fill me-2"></i>VotaLegis</h5>
    <small>{{ municipio?.nome || 'Câmara Municipal' }}</small>
  </div>
  <nav class="mt-2">
    {{{ await $slots.sidebar() }}}
  </nav>
  <div class="position-absolute bottom-0 w-100 p-3" style="border-top:1px solid #334155">
    <div class="small text-white fw-semibold mb-1">{{ usuario?.nome || 'Usuário' }}</div>
    <a href="/logout" class="btn btn-sm btn-outline-danger w-100"><i class="bi bi-box-arrow-right me-1"></i>Sair</a>
  </div>
</div>
<div class="main-content">
  {{{ await $slots.content() }}}
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
{{{ await $slots.scripts() }}}
</body>
</html>
