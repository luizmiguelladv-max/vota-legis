  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght=400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Plus Jakarta Sans', sans-serif; }
    body { background: #0f172a; color: #e2e8f0; min-height: 100vh; }
    .sidebar { width: 240px; background: #1e293b; border-right: 1px solid #334155; min-height: 100vh; position: fixed; top: 0; left: 0; z-index: 100; }
    .sidebar-brand { padding: 1.25rem 1rem; border-bottom: 1px solid #334155; }
    .sidebar-brand h5 { color: #60a5fa; font-weight: 700; margin: 0; }
    .sidebar-brand small { color: #64748b; font-size: 0.7rem; }
    .sidebar-nav .nav-link { color: #94a3b8; padding: .5rem 1rem; border-radius: 8px; margin: 2px 8px; transition: all .2s; font-size: .875rem; }
    .sidebar-nav .nav-link:hover, .sidebar-nav .nav-link.active { background: #1d4ed8; color: #fff; }
    .sidebar-nav .nav-link i { width: 20px; margin-right: 8px; }
    .sidebar-nav .nav-section { color: #475569; font-size: .65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; padding: .75rem 1.5rem .25rem; }
    .main-content { margin-left: 240px; padding: 1.5rem; }
    .topbar { background: #1e293b; border-bottom: 1px solid #334155; padding: .75rem 1.5rem; margin: -1.5rem -1.5rem 1.5rem; display: flex; align-items: center; justify-content: space-between; }
    .topbar-title { font-weight: 600; color: #f1f5f9; }
    .card { background: #1e293b; border: 1px solid #334155; border-radius: 12px; }
    .card-header { background: transparent; border-bottom: 1px solid #334155; }
    .badge-status { font-size: .7rem; padding: .3em .6em; border-radius: 20px; }
    .btn-primary { background: #1d4ed8; border-color: #1d4ed8; }
    .btn-primary:hover { background: #1e40af; border-color: #1e40af; }
    .table { color: #cbd5e1; }
    .table thead th { color: #64748b; font-size: .75rem; text-transform: uppercase; letter-spacing: .5px; border-color: #334155; }
    .table td { border-color: #1e293b; }
    .form-control, .form-select { background: #0f172a; border-color: #334155; color: #e2e8f0; }
    .form-control:focus, .form-select:focus { background: #0f172a; border-color: #1d4ed8; color: #e2e8f0; box-shadow: 0 0 0 .2rem rgba(29,78,216,.25); }
    .alert-info { background: #1e3a5f; border-color: #1d4ed8; color: #93c5fd; }
    .alert-success { background: #14532d; border-color: #16a34a; color: #86efac; }
    .alert-danger { background: #450a0a; border-color: #dc2626; color: #fca5a5; }
    .modal-content { background: #1e293b; border: 1px solid #334155; }
    .modal-header { border-bottom: 1px solid #334155; }
    .modal-footer { border-top: 1px solid #334155; }
  </style>
  @yield('styles')
</head>
<body>

